APP_ENV=local
APP_NAME=ragmax
APP_VERSION=0.1.0
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DATABASE_URL=postgresql+asyncpg://ragmax:ragmax@localhost:5432/ragmax

AUTH_JWT_SECRET=change-this-secret-before-production
AUTH_ACCESS_TOKEN_MINUTES=15
AUTH_REFRESH_TOKEN_DAYS=7
AUTH_REFRESH_COOKIE_NAME=ragmax_refresh_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_BOOTSTRAP_USERNAME=admin
AUTH_BOOTSTRAP_PASSWORD=admin
AUTH_BOOTSTRAP_ROUTES=/indexing,/retrieval,/evaluation

DEFAULT_FILE_PARSER=simple_directory_reader
LLAMAPARSE_DEFAULT_TIER=agentic
LLAMAPARSE_DEFAULT_VERSION=latest
LLAMA_CLOUD_API_KEY=

VECTOR_INDEX_ENABLED=false
VECTOR_SPARSE_INDEX_ENABLED=true
EMBEDDING_PROVIDER=hash
EMBEDDING_DIMENSION=384
HASH_EMBEDDING_MODEL=hash-embedding-v1
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_BATCH_SIZE=16

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

RETRIEVAL_ENABLED=false

# Query Processing
RETRIEVAL_QUERY_TRANSFORMATION=original
RETRIEVAL_QUERY_MULTI_QUERY_COUNT=3

# Hybrid Retrieval (BM25 + Vector)
RETRIEVAL_BM25_ENABLED=false
RETRIEVAL_BM25_TOP_K=100
RETRIEVAL_FUSION_STRATEGY=rrf
RETRIEVAL_FUSION_RRF_K=60

# Reranking
RETRIEVAL_RERANKING_STAGES=coarse
RETRIEVAL_RERANKER_FINE=none
RETRIEVAL_RERANKER_FINE_MODEL=BAAI/bge-reranker-v2-m3
RETRIEVAL_RERANKER_FINE_DEVICE=cpu
RETRIEVAL_RERANKER_FINE_BATCH_SIZE=16
RETRIEVAL_RERANKER_FINE_MAX_LENGTH=512
RETRIEVAL_RERANKER_COARSE_TOP_K=100
RETRIEVAL_RERANKER_FINE_TOP_K=20

# Context Building
RETRIEVAL_CONTEXT_STRATEGY=child_with_parent
RETRIEVAL_CONTEXT_MAX_LENGTH=2000
RETRIEVAL_CONTEXT_DEDUPLICATION_THRESHOLD=0.95

# LLM Answer Generation
RETRIEVAL_ANSWER_GENERATOR=extractive
RETRIEVAL_LLM_PROVIDER=openai
RETRIEVAL_LLM_MODEL=gpt-4o-mini
RETRIEVAL_LLM_BASE_URL=
RETRIEVAL_LLM_API_KEY=
RETRIEVAL_LLM_TEMPERATURE=0.0
RETRIEVAL_LLM_MAX_TOKENS=1000

# Multi-Query Transformation LLM (separate from answer generation)
# Recommended: Use DeepSeek V3 for cost-effective query expansion
RETRIEVAL_QUERY_LLM_PROVIDER=openai
RETRIEVAL_QUERY_LLM_MODEL=deepseek-chat
RETRIEVAL_QUERY_LLM_BASE_URL=https://api.deepseek.com/v1
RETRIEVAL_QUERY_LLM_API_KEY=
